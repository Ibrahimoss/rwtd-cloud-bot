# Copy to .env and fill in. Never commit .env.

# --- Bot configuration ---
GAME_NAME=rwtd
STATE_MACHINE=bot/states/rwtd.yaml
ADB_HOST=android
ADB_PORT=5555
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=3

# --- Android emulator ---
ANDROID_WIDTH=720
ANDROID_HEIGHT=1280
ANDROID_DPI=320
ANDROID_FPS=30

# --- Monitoring (optional) ---
DISCORD_WEBHOOK_URL=
HEALTHCHECK_PORT=8080

# --- Oracle Cloud (only used by terraform/) ---
# Fill in terraform.tfvars instead, not here.
